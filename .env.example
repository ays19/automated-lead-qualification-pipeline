# GROQ_API_KEY: Required for AI-powered candidate scoring and mock profile generation.
GROQ_API_KEY=

# GROQ_MODEL: Optional. Defaults to the model chosen in server.ts (llama-3.1-8b-instant).
GROQ_MODEL=
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# APIFY_API_KEY: Optional. Your Apify API token used to scrape real LinkedIn profiles.
# If omitted, the platform falls back to Groq-powered candidate profile synthesis.
APIFY_API_KEY=

# APIFY_ACTOR_ID: Optional. The Apify actor ID used for scraping. Defaults to bebity/linkedin-profile-scraper.
APIFY_ACTOR_ID=harvestapi/linkedin-profile-scraper

# Sender Information: Used in cold email generation signatures.
SENDER_NAME=
SENDER_TITLE=
SENDER_COMPANY=
